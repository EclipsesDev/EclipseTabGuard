{
    "manifest_version": 3,
    "name": "EclipseTabGuard - Smart Tab Suspender",
    "description": "Automatically suspends inactive tabs to save memory, with smart rules to protect pinned, audible, and whitelisted tabs.",
    "version": "1.0.4",
    "browser_specific_settings": {
        "gecko": {
            "id": "eclipsetabguard@eclipsesdev",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "icons/icon-48.png",
        "default_title": "EclipseTabGuard"
    },
    "background": {
        "service_worker": "background/index.js",
        "scripts": ["background/index.js"]
    },
    "permissions": [
        "tabs",
        "storage",
        "alarms",
        "idle"
    ]
}